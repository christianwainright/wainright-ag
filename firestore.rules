rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Guesses Collection: Anyone can read guesses to build stats, but creation requires invitation passcode.
    match /guesses/{guessId} {
      allow read: if true;
      allow create: if request.resource.data.passcode == 'tinyhuman';
      allow update, delete: if false;
    }
    
    // RSVPs Collection: Anyone with the invitation passcode can submit an RSVP, write-only.
    match /rsvps/{rsvpId} {
      allow create: if request.resource.data.passcode == 'tinyhuman';
      allow read, update, delete: if false;
    }

    // Contacts Collection: Anyone can submit a contact request, but they are write-only.
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Config Collection: Completely private. Only Cloud Functions/Admins can read/write.
    match /config/{document} {
      allow read, write: if false;
    }
  }
}
