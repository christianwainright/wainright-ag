rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Guesses Collection: Anyone can read guesses to build stats, anyone can submit a new guess.
    match /guesses/{guessId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    
    // RSVPs Collection: Anyone can submit an RSVP, but RSVPs are write-only to protect guest privacy.
    match /rsvps/{rsvpId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Contacts Collection: Anyone can submit a contact request, but they are write-only.
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
